{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (admin or regular user).",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        }
      },
      "required": ["name", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A t-shirt order.",
      "type": "object",
      "properties": {
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "whatsapp": { "type": "string" },
            "address": { "type": "string" },
            "group": { "type": "string" }
          },
          "required": ["name", "whatsapp", "address"]
        },
        "items": {
          "type": "array",
          "description": "List of order items"
        },
        "total": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "createdBy": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      },
      "required": ["customer", "items", "total", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores all t-shirt orders."
    }
  }
}
